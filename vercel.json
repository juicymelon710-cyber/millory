{
  "functions": {
    "api/index.js": {
      "includeFiles": [
        "server/**",
        "data/**",
        "scripts/**"
      ]
    }
  },
  "rewrites": [
    {
      "source": "/api/(.*)",
      "destination": "/api/index.js"
    },
    {
      "source": "/(.*)",
      "destination": "/$1"
    }
  ]
}
